import test from 'node:test';
import assert from 'node:assert';
import puppeteer from 'puppeteer';
import path from 'node:path';
import fs from 'node:fs';
import http from 'node:http';
import url, { fileURLToPath } from 'node:url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

let server;
let browser;
let page;

async function startServer() {
  return await new Promise((resolve) => {
    const srv = http.createServer((req, res) => {
      const uri = url.parse(req.url).pathname;
      let filename;
      if (uri === '/') {
        filename = path.join(__dirname, '..', 'grid-template-studio.html');
      } else if (uri.startsWith('/core/') || uri.startsWith('/templates/')) {
        filename = path.join(__dirname, '..', '..', uri.substring(1));
      } else if (uri.startsWith('/src/') || uri.startsWith('/styles/') || uri.startsWith('/test/')) {
        filename = path.join(__dirname, '..', uri.substring(1));
      } else {
        const cleanUri = uri.replace(/^\//, '');
        filename = path.join(__dirname, '..', cleanUri);
      }
      const baseDir = path.join(__dirname, '../..');
      if (!filename.startsWith(baseDir)) {
        res.writeHead(403);
        return res.end('Forbidden');
      }
      fs.readFile(filename, (err, data) => {
        if (err) {
          res.writeHead(404);
          return res.end('File not found');
        }
        const ext = path.extname(filename);
        const contentType = ext === '.js' ? 'application/javascript'
          : ext === '.css' ? 'text/css'
          : ext === '.json' ? 'application/json'
          : 'text/html';
        res.writeHead(200, { 'Content-Type': contentType });
        res.end(data);
      });
    });
    srv.listen(3000, () => resolve(srv));
  });
}

async function loadTemplateStudio(targetPage) {
  await targetPage.goto('http://localhost:3000');
  await targetPage.waitForFunction(() => window.TemplateStudio && window.TemplateStudio.state, { timeout: 10000 });
  await targetPage.evaluate(() => {
    if (window.TemplateStudio.state.boxes.length === 0) {
      window.TemplateStudio.addNewRegion();
      window.TemplateStudio.addNewRegion();
    }
  });
}

async function hasProductionContent(targetPage) {
  return await targetPage.evaluate(() => {
    const container = document.querySelector('#productionPreview');
    return container.children.length > 0 &&
      !container.innerHTML.includes('Invalid') &&
      !container.innerHTML.includes('Loading');
  });
}

test.before(async () => {
  server = await startServer();
});

test.beforeEach(async () => {
  browser = await puppeteer.launch({ headless: true, args: ['--no-sandbox', '--disable-setuid-sandbox'] });
  page = await browser.newPage();
});

test.afterEach(async () => {
  if (browser) {
    await browser.close();
    browser = null;
  }
});

test.after(async () => {
  if (server) {
    server.close();
    server = null;
  }
});

test('should render production view on initial load', async () => {
  await loadTemplateStudio(page);
  await page.click('[data-preview-view="production"]');
  await page.waitForTimeout(300);
  assert.strictEqual(await hasProductionContent(page), true);
});

test('should handle canvas -> production -> canvas -> production switches', async () => {
  await loadTemplateStudio(page);

  const checkProductionRender = async () => hasProductionContent(page);

  await page.click('[data-preview-view="production"]');
  await page.waitForTimeout(300);
  assert.strictEqual(await checkProductionRender(), true);

  await page.click('[data-preview-view="canvas"]');
  await page.waitForTimeout(200);

  await page.evaluate(() => window.TemplateStudio.addNewRegion());
  await page.waitForTimeout(200);

  await page.click('[data-preview-view="production"]');
  await page.waitForTimeout(300);
  assert.strictEqual(await checkProductionRender(), true);

  await page.click('[data-preview-view="canvas"]');
  await page.waitForTimeout(200);

  await page.evaluate(() => {
    if (window.TemplateStudio.state.selectedBoxId) {
      window.TemplateStudio.deleteSelectedRegion();
    }
  });
  await page.waitForTimeout(200);

  await page.click('[data-preview-view="production"]');
  await page.waitForTimeout(300);
  assert.strictEqual(await checkProductionRender(), true);
});
  
test('should handle slide -> production switches', async () => {
  await loadTemplateStudio(page);

  await page.click('[data-preview-view="slide"]');
  await page.waitForTimeout(200);

  await page.evaluate(() => window.TemplateStudio.addNewRegion());
  await page.waitForTimeout(200);

  await page.click('[data-preview-view="production"]');
  await page.waitForTimeout(300);
  assert.strictEqual(await hasProductionContent(page), true);
});
  
test('should handle rapid view switches', async () => {
  await loadTemplateStudio(page);

  const checkProductionRender = async () => hasProductionContent(page);

  for (let i = 0; i < 3; i++) {
    await page.click('[data-preview-view="canvas"]');
    await page.waitForTimeout(50);

    await page.click('[data-preview-view="production"]');
    await page.waitForTimeout(200);
    assert.strictEqual(await checkProductionRender(), true);

    await page.click('[data-preview-view="slide"]');
    await page.waitForTimeout(50);

    await page.click('[data-preview-view="production"]');
    await page.waitForTimeout(200);
    assert.strictEqual(await checkProductionRender(), true);
  }
});
  
  test('should skip production render when panel is hidden', async () => {
    await page.goto('http://localhost:3000');
    await page.waitForFunction(() => window.TemplateStudio && window.TemplateStudio.state, { timeout: 10000 });
    
    // Stay on canvas view
    await page.click('[data-preview-view="canvas"]');
    await page.waitForTimeout(200);
    
    // Capture console logs
    const logs = [];
    page.on('console', msg => {
      if (msg.text().includes('Panel is not visible, skipping render')) {
        logs.push(msg.text());
      }
    });
    
    // Try to render production while hidden
    await page.evaluate(() => {
      window.TemplateStudio.renderProductionSlide(document.querySelector('#productionPreview'));
    });
    
    // Should have skipped render
    expect(logs.length).toBeGreaterThan(0);
    
    // Container should be empty
    const containerChildren = await page.evaluate(() => {
      return document.querySelector('#productionPreview').children.length;
    });
    
    expect(containerChildren).toBe(0);
  });
  
  test('should resize correctly when container dimensions change', async () => {
    await page.goto('http://localhost:3000');
    await page.waitForFunction(() => window.TemplateStudio && window.TemplateStudio.state, { timeout: 10000 });
    
    // Add regions
    await page.evaluate(() => {
      if (window.TemplateStudio.state.boxes.length === 0) {
        window.TemplateStudio.addNewRegion();
        window.TemplateStudio.addNewRegion();
      }
    });
    
    // Switch to production
    await page.click('[data-preview-view="production"]');
    await page.waitForTimeout(300);
    
    // Get initial dimensions
    const initialDimensions = await page.evaluate(() => {
      const container = document.querySelector('#productionPreview');
      const child = container.firstElementChild;
      return {
        width: child ? child.offsetWidth : 0,
        height: child ? child.offsetHeight : 0
      };
    });
    
    // Change panel size
    await page.evaluate(() => {
      const panel = document.querySelector('.production-preview-panel');
      panel.style.width = '600px';
      panel.style.height = '400px';
    });
    
    // Wait for resize observer to trigger
    await page.waitForTimeout(200);
    
    // Check new dimensions
    const newDimensions = await page.evaluate(() => {
      const container = document.querySelector('#productionPreview');
      const child = container.firstElementChild;
      return {
        width: child ? child.offsetWidth : 0,
        height: child ? child.offsetHeight : 0
      };
    });
    
    // Dimensions should have changed
    expect(newDimensions.width).not.toBe(initialDimensions.width);
    expect(newDimensions.height).not.toBe(initialDimensions.height);
  });
});
