import { jest } from '@jest/globals';

describe('Production Renderer Visibility Logic', () => {
  let container;
  let parentPanel;
  let workbench;
  let mockState;
  
  beforeEach(() => {
    // Set up DOM structure
    document.body.innerHTML = `
      <div class="preview-workbench" id="previewWorkbench">
        <div class="production-preview-panel">
          <div id="productionPreview" class="production-preview-surface"></div>
        </div>
      </div>
    `;
    
    container = document.querySelector('#productionPreview');
    parentPanel = document.querySelector('.production-preview-panel');
    workbench = document.querySelector('#previewWorkbench');
    
    // Mock state
    mockState = {
      boxes: [
        { id: 'box1', x: 0, y: 0, width: 100, height: 100, metadata: { role: 'title' } }
      ],
      canvasWidth: 1920,
      canvasHeight: 1080,
      brand: { id: 'dark', variant: 'default' }
    };
    
    window.TemplateStudio = { state: mockState };
  });
  
  afterEach(() => {
    document.body.innerHTML = '';
    delete window.TemplateStudio;
  });
  
  describe('Panel Visibility Detection', () => {
    test('should detect when panel is hidden by CSS display: none', async () => {
      parentPanel.style.display = 'none';
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      const consoleSpy = jest.spyOn(console, 'log').mockImplementation();
      
      await renderProductionSlide(container);
      
      expect(consoleSpy).toHaveBeenCalledWith('Production render: Panel is not visible, skipping render');
      expect(container._isRendering).toBe(false);
      
      consoleSpy.mockRestore();
    });
    
    test('should detect when panel is hidden by parent display: none', async () => {
      workbench.style.display = 'none';
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      const consoleSpy = jest.spyOn(console, 'log').mockImplementation();
      
      await renderProductionSlide(container);
      
      expect(consoleSpy).toHaveBeenCalledWith('Production render: Panel is not visible, skipping render');
      
      consoleSpy.mockRestore();
    });
    
    test('should render when panel is visible with display: flex', async () => {
      parentPanel.style.display = 'flex';
      Object.defineProperty(parentPanel, 'clientWidth', { value: 800 });
      Object.defineProperty(parentPanel, 'clientHeight', { value: 600 });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      await renderProductionSlide(container);
      
      expect(container.children.length).toBeGreaterThan(0);
      expect(container.innerHTML).not.toContain('Invalid container dimensions');
    });
    
    test('should render when panel is visible with display: block', async () => {
      parentPanel.style.display = 'block';
      Object.defineProperty(parentPanel, 'clientWidth', { value: 800 });
      Object.defineProperty(parentPanel, 'clientHeight', { value: 600 });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      await renderProductionSlide(container);
      
      expect(container.children.length).toBeGreaterThan(0);
    });
  });
  
  describe('CSS View-based Visibility', () => {
    test('should skip render when workbench data-view is not production', async () => {
      workbench.dataset.view = 'canvas';
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      const consoleSpy = jest.spyOn(console, 'log').mockImplementation();
      
      await renderProductionSlide(container);
      
      expect(consoleSpy).toHaveBeenCalledWith('Production render: Panel is not visible, skipping render');
      
      consoleSpy.mockRestore();
    });
    
    test('should render when workbench data-view is production', async () => {
      workbench.dataset.view = 'production';
      parentPanel.style.display = 'flex';
      Object.defineProperty(parentPanel, 'clientWidth', { value: 800 });
      Object.defineProperty(parentPanel, 'clientHeight', { value: 600 });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      await renderProductionSlide(container);
      
      expect(container.children.length).toBeGreaterThan(0);
    });
  });
  
  describe('Visibility Change Detection', () => {
    test('should set up MutationObserver for visibility changes', async () => {
      parentPanel.style.display = 'flex';
      Object.defineProperty(parentPanel, 'clientWidth', { value: 800 });
      Object.defineProperty(parentPanel, 'clientHeight', { value: 600 });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      await renderProductionSlide(container);
      
      expect(container._visibilityObserver).toBeDefined();
    });
    
    test('should observe workbench data-view attribute changes', async () => {
      parentPanel.style.display = 'flex';
      Object.defineProperty(parentPanel, 'clientWidth', { value: 800 });
      Object.defineProperty(parentPanel, 'clientHeight', { value: 600 });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      await renderProductionSlide(container);
      
      // Check that MutationObserver is observing the workbench
      const observer = container._visibilityObserver;
      expect(observer).toBeDefined();
    });
  });
  
  describe('Edge Cases', () => {
    test('should handle missing parent panel gracefully', async () => {
      // Remove parent panel
      parentPanel.remove();
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      // Should not throw error
      await expect(renderProductionSlide(container)).resolves.not.toThrow();
    });
    
    test('should handle computedStyle access errors', async () => {
      // Mock getComputedStyle to throw error
      const originalGetComputedStyle = window.getComputedStyle;
      window.getComputedStyle = jest.fn(() => {
        throw new Error('Access denied');
      });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      // Should handle error gracefully
      await expect(renderProductionSlide(container)).resolves.not.toThrow();
      
      // Restore original
      window.getComputedStyle = originalGetComputedStyle;
    });
    
    test('should not render when panel has zero dimensions but is visible', async () => {
      parentPanel.style.display = 'flex';
      Object.defineProperty(parentPanel, 'clientWidth', { value: 0 });
      Object.defineProperty(parentPanel, 'clientHeight', { value: 0 });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      const consoleSpy = jest.spyOn(console, 'warn').mockImplementation();
      
      await renderProductionSlide(container);
      
      // Should attempt to retry rather than showing "Invalid dimensions" immediately
      expect(container.innerHTML).toContain('Loading...');
      
      consoleSpy.mockRestore();
    });
  });
  
  describe('Interaction with ResizeObserver', () => {
    test('should set up ResizeObserver when panel is visible', async () => {
      parentPanel.style.display = 'flex';
      Object.defineProperty(parentPanel, 'clientWidth', { value: 800 });
      Object.defineProperty(parentPanel, 'clientHeight', { value: 600 });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      await renderProductionSlide(container);
      
      expect(container._resizeObserver).toBeDefined();
    });
    
    test('should not set up ResizeObserver when panel is hidden', async () => {
      parentPanel.style.display = 'none';
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      
      await renderProductionSlide(container);
      
      expect(container._resizeObserver).toBeUndefined();
    });
    
    test('should observe parent panel instead of container', async () => {
      parentPanel.style.display = 'flex';
      Object.defineProperty(parentPanel, 'clientWidth', { value: 800 });
      Object.defineProperty(parentPanel, 'clientHeight', { value: 600 });
      
      const { renderProductionSlide } = await import('../src/canvas/production-renderer.js');
      const consoleSpy = jest.spyOn(console, 'log').mockImplementation();
      
      await renderProductionSlide(container);
      
      expect(consoleSpy).toHaveBeenCalledWith(
        expect.stringContaining('Observing element: production-preview-panel')
      );
      
      consoleSpy.mockRestore();
    });
  });
});
